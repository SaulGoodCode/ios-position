# iOS Location Spoofing - Environment Variables
# Copy this to .env and customize

# Your server's public domain or IP
SERVER_DOMAIN=locspoof.local
VPN_HOST=vpn.locspoof.local
API_HOST=api.locspoof.local

# VPN user credentials
VPN_USERNAME=user@example.com
VPN_PASSWORD=changeme

# Secret key for signing config profiles
PROFILE_SECRET=change-this-to-a-random-string
